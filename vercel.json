{
  "version": 2,
  "name": "terminal-leads",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "runtime": "vercel-nodejs@20"
    }
  },
  "installCommand": "npm install",
  "buildCommand": "npm run build"
}
